package com.example.bookstore.services;

import com.example.bookstore.entities.Payment;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.pdmodel.PDPage;
import org.apache.pdfbox.pdmodel.PDPageContentStream;
import org.apache.pdfbox.pdmodel.common.PDRectangle;
import org.apache.pdfbox.pdmodel.font.PDType1Font;
import org.apache.pdfbox.pdmodel.font.PDType1Font;
import org.springframework.stereotype.Service;

import java.io.ByteArrayOutputStream;
import java.io.IOException;
import java.text.SimpleDateFormat;
import java.util.Date;

@Service
public class PdfGeneratorService {

    public byte[] generatePaymentInvoice(Payment payment) throws IOException {
        try (PDDocument document = new PDDocument()) {
            // Créer une page A4
            PDPage page = new PDPage(PDRectangle.A4);
            document.addPage(page);

            // Polices
            PDType1Font fontBold = PDType1Font.HELVETICA_BOLD;
            PDType1Font fontRegular = PDType1Font.HELVETICA;
            PDType1Font fontTitle = PDType1Font.HELVETICA_BOLD;

            try (PDPageContentStream contentStream = new PDPageContentStream(document, page)) {
                // En-tête
                drawHeader(contentStream, fontTitle, 20, "ASTRUM", "Facture #" + payment.getId());

                // Informations client et facture
                float startY = 650;
                drawSectionTitle(contentStream, fontBold, startY, "Informations de Facturation");
                startY = drawInfoRow(contentStream, fontRegular, startY - 20, "Numéro de facture:", payment.getId().toString());
                startY = drawInfoRow(contentStream, fontRegular, startY, "Date:", new SimpleDateFormat("dd/MM/yyyy").format(new Date()));
                startY = drawInfoRow(contentStream, fontRegular, startY, "ID Panier:", payment.getCartId().toString());
                startY = drawInfoRow(contentStream, fontRegular, startY, "Méthode de paiement:", payment.getPaymentMethod().name());
                startY = drawInfoRow(contentStream, fontRegular, startY, "Statut:", payment.getPaymentStatus().name());

                String bookDesc = "Livre ABC";
                Double price = 29.99;

                // Détails de paiement
                startY -= 30;
                drawSectionTitle(contentStream, fontBold, startY, "Détails du Paiement");

                // Tableau des articles (exemple)
                startY -= 20;
                drawTableHeader(contentStream, fontBold, startY);
                startY -= 20;
                drawTableRow(contentStream, fontRegular, startY, "1", bookDesc, price.toString() , payment.getAmount().toString());

                // Total
                startY -= 30;
                drawTotal(contentStream, fontBold, startY, "29.99");

                // Pied de page
                drawFooter(contentStream, fontRegular, 50, "Merci pour votre achat !");
            }

            ByteArrayOutputStream outputStream = new ByteArrayOutputStream();
            document.save(outputStream);
            return outputStream.toByteArray();
        }
    }

    private void drawHeader(PDPageContentStream contentStream, PDType1Font font, float y, String company, String title) throws IOException {
        contentStream.beginText();
        contentStream.setFont(font, 24);
        contentStream.newLineAtOffset(50, y);
        contentStream.showText(company);
        contentStream.endText();

        contentStream.beginText();
        contentStream.setFont(font, 18);
        contentStream.newLineAtOffset(50, y - 30);
        contentStream.showText(title);
        contentStream.endText();

        // Ligne de séparation
        contentStream.moveTo(50, y - 40);
        contentStream.lineTo(550, y - 40);
        contentStream.stroke();
    }

    private float drawInfoRow(PDPageContentStream contentStream, PDType1Font font, float y, String label, String value) throws IOException {
        contentStream.beginText();
        contentStream.setFont(font, 12);
        contentStream.newLineAtOffset(50, y);
        contentStream.showText(label);
        contentStream.endText();

        contentStream.beginText();
        contentStream.setFont(font, 12);
        contentStream.newLineAtOffset(200, y);
        contentStream.showText(value);
        contentStream.endText();

        return y - 20;
    }

    private void drawSectionTitle(PDPageContentStream contentStream, PDType1Font font, float y, String title) throws IOException {
        contentStream.beginText();
        contentStream.setFont(font, 14);
        contentStream.newLineAtOffset(50, y);
        contentStream.showText(title);
        contentStream.endText();
    }

    private void drawTableHeader(PDPageContentStream contentStream, PDType1Font font, float y) throws IOException {
        String[] headers = {"#", "Description", "Prix Unitaire", "Total"};
        float[] positions = {50, 150, 350, 450};

        for (int i = 0; i < headers.length; i++) {
            contentStream.beginText();
            contentStream.setFont(font, 12);
            contentStream.newLineAtOffset(positions[i], y);
            contentStream.showText(headers[i]);
            contentStream.endText();
        }

        // Ligne sous l'en-tête
        contentStream.moveTo(50, y - 5);
        contentStream.lineTo(550, y - 5);
        contentStream.stroke();
    }

    private void drawTableRow(PDPageContentStream contentStream, PDType1Font font, float y, String... values) throws IOException {
        float[] positions = {50, 150, 350, 450};

        for (int i = 0; i < values.length; i++) {
            contentStream.beginText();
            contentStream.setFont(font, 12);
            contentStream.newLineAtOffset(positions[i], y);
            contentStream.showText(values[i]);
            contentStream.endText();
        }
    }

    private void drawTotal(PDPageContentStream contentStream, PDType1Font font, float y, String total) throws IOException {
        contentStream.beginText();
        contentStream.setFont(font, 14);
        contentStream.newLineAtOffset(400, y);
        contentStream.showText("Total:");
        contentStream.endText();

        contentStream.beginText();
        contentStream.setFont(font, 14);
        contentStream.newLineAtOffset(450, y);
        contentStream.showText(total + " TND");
        contentStream.endText();
    }

    private void drawFooter(PDPageContentStream contentStream, PDType1Font font, float y, String text) throws IOException {
        contentStream.beginText();
        contentStream.setFont(font, 10);
        contentStream.newLineAtOffset(50, y);
        contentStream.showText(text);
        contentStream.endText();
    }
}